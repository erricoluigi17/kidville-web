    "deny": [
      "Read(.env.local)",
      "Read(.env)",
      "Read(.env.*.local)",

      "Bash(npm run e2e:*)",
      "Bash(npx playwright test:*)",
      "Bash(node scripts/seed-e2e.mjs:*)",

      "Bash(supabase db reset:*)",
      "Bash(npx supabase db reset:*)",

      "Bash(git push --force:*)",
      "Bash(git push -f:*)",

      "Bash(sudo:*)",

      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf /Users:*)",
      "Bash(rm -rf /System:*)",
      "Bash(rm -rf /Applications:*)",
      "Bash(rm -rf /Library:*)",
      "Bash(rm -rf /usr:*)",
      "Bash(rm -rf /etc:*)",
      "Bash(rm -rf /var:*)"
    ]
  },

  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/verify_gate.sh\"",
            "timeout": 1800
          }
        ]
      }
    ]
  }
}
