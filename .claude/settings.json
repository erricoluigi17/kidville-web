{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "permissions": {
    "defaultMode": "acceptEdits",

    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "TodoWrite",
      "Task",
      "Workflow",

      "Agent(scrittore-di-piani)",
      "Agent(esecutore-opus)",
      "Agent(tester-opus-backend)",
      "Agent(tester-opus-frontend)",
      "Agent(tester-opus-design)",
      "Agent(tester-opus-debug)",
      "Agent(tester-opus-mobile-android)",
      "Agent(tester-opus-mobile-ios)",
      "Agent(tester-opus-log)",
      "Agent(tester-opus-sicurezza)",
      "Agent(tester-opus-privacy)",
      "Agent(tester-opus-localizzazione)",
      "Agent(tester-opus-accessibilita)",
      "Agent(Explore)",
      "Agent(general-purpose)",

      "Bash(npm run:*)",
      "Bash(npm ci)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npm exec:*)",
      "Bash(npm ls:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(tsx:*)",

      "Bash(git:*)",
      "Bash(gh:*)",

      "Bash(vercel:*)",
      "Bash(supabase:*)",
      "Bash(psql:*)",

      "Bash(maestro:*)",
      "Bash(~/.maestro/bin/maestro:*)",
      "Bash(adb:*)",
      "Bash(emulator:*)",
      "Bash(avdmanager:*)",
      "Bash(sdkmanager:*)",
      "Bash(./gradlew:*)",
      "Bash(gradle:*)",
      "Bash(xcrun:*)",
      "Bash(xcodebuild:*)",
      "Bash(pod:*)",
      "Bash(open:*)",
      "Bash(java:*)",

      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(chmod:*)",
      "Bash(touch:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
